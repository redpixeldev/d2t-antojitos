---
const stats = [
	{ value: '100%', label: 'Homemade' },
	{ value: 'Daily', label: 'Lunch Special' },
	{ value: 'Family', label: 'Run & Cozy' },
];
---

<section
	id='about'
	class='bg-brand-cream py-20 md:py-28'
	aria-labelledby='about-title'
>
	<div class='container grid items-center gap-14 lg:grid-cols-2 lg:gap-20'>
		<!-- Image with amber backing + sticker -->
		<div class='relative'>
			<!-- Amber offset card peeking out bottom-right -->
			<div
				class='absolute inset-0 translate-x-4 translate-y-4 rounded-[2rem] bg-brand-amber'
				aria-hidden='true'
			>
			</div>

			<div class='relative overflow-hidden rounded-[2rem] shadow-xl shadow-brand-charcoal/15 ring-1 ring-brand-charcoal/10'>
				<img
					src='/img/about.jpg'
					alt='A Dominican plate — yellow rice with stewed meat and sweet fried plantains'
					class='aspect-[6/5] w-full object-cover border-3 border-black rounded-[2rem]'
					loading='lazy'
					decoding='async'
				/>
			</div>

			<!-- Greeting sticker — same look as the header button, but non-interactive -->
			<div
				class='btn btn-primary pointer-events-none absolute -top-6 -left-2 -rotate-6'
				aria-hidden='true'
			>
				<span class='font-script text-2xl md:text-3xl'>¡Hola, vecino!</span>
			</div>
		</div>

		<!-- Copy -->
		<div>
			<p class='script-accent text-[#e33127]'>A neighborhood hidden gem</p>
			<h2
				id='about-title'
				class='mt-2 text-4xl text-brand-charcoal uppercase md:text-5xl'
			>
				About Us
			</h2>
			<p class='mt-5 text-lg leading-relaxed text-brand-ink/80'>
				Explore the authentic Dominican flavor at Antojitos, where every bite transports you to the streets of Santo
				Domingo. With a passion for vibrant flavors, we offer a wide selection of snacks — from chimis and burgers to
				natural juices and appetizers — perfect for any time of the day.
			</p>

			<dl class='mt-10 flex flex-wrap gap-x-9 gap-y-5'>
				{
					stats.map((s) => (
						<div>
							<dt class='font-display text-4xl text-brand-red'>{s.value}</dt>
							<dd class='mt-0.5 text-[13px] font-bold tracking-wide text-brand-charcoal uppercase'>{s.label}</dd>
						</div>
					))
				}
			</dl>
		</div>
	</div>
</section>
