---
import Logo from '@components/Logo.astro';
import { site } from '@data/content';
const year = new Date().getFullYear();
---

<footer class='bg-[#241b12] text-white'>
	<div
		class='container flex flex-col items-center gap-10 py-14 sm:flex-row sm:justify-between sm:gap-6 md:py-16'
	>
		<!-- Logo -->
		<Logo class='h-24' />

		<!-- Contact · social · copyright -->
		<div class='flex flex-col items-center gap-2.5 text-center sm:items-end sm:text-right'>
			<a
				href={site.phoneHref}
				class='text-xl font-bold tracking-wide text-brand-amber transition-colors hover:text-[#ea342c] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-amber'
			>
				{site.phone}
			</a>

			<a
				href={site.social.instagram}
				target='_blank'
				rel='noopener noreferrer'
				class='inline-flex items-center gap-2 font-bold text-white transition-colors hover:text-brand-amber focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-amber'
			>
				<i
					class='ri-instagram-line text-xl'
					aria-hidden='true'></i>
				@antojitossomerville
			</a>

			<p class='text-sm text-white/55'>© {year} Antojitos · The ultimate Dominican food experience</p>
		</div>
	</div>
</footer>
