---
import MenuCategory from '@components/MenuCategory.astro';
import { menuLeft, menuRight, site } from '@data/content';
---

<section
	id='menu'
	class='scroll-mt-20 bg-brand-cream py-20 md:py-28'
	aria-labelledby='menu-title'
>
	<div class='container'>
		<div class='text-center'>
			<p class='script-accent text-brand-red'>Everything we cook</p>
			<h2
				id='menu-title'
				class='mt-1 text-4xl uppercase md:text-6xl'
			>
				The Full Menu
			</h2>
			<a
				href={site.phoneHref}
				class='btn btn-primary mt-6'
			>
				<i
					class='ri-phone-fill'
					aria-hidden='true'></i>
				Call to order · {site.phone}
			</a>
		</div>

		<div class='mt-12 grid items-start gap-6 lg:grid-cols-2'>
			<div class='space-y-6'>
				{menuLeft.map((category) => <MenuCategory category={category} />)}
			</div>
			<div class='space-y-6'>
				{menuRight.map((category) => <MenuCategory category={category} />)}
			</div>
		</div>

		<div class='mt-12 text-center'>
			<a
				href={site.phoneHref}
				class='btn btn-dark'
			>
				<i
					class='ri-phone-fill'
					aria-hidden='true'></i>
				Hungry? Call to Order now
			</a>
		</div>
	</div>
</section>
