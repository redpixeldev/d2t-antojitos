---
import { gallery, site } from '@data/content';
---

<section
	class='bg-brand-cream pt-20 md:pt-28'
	aria-label='Photo gallery'
>
	<div class='container'>
		<div class='grid grid-cols-2 gap-3 md:grid-cols-4 md:gap-4'>
			{
				gallery.map((photo) => (
					<a
						href={site.social.instagram}
						target='_blank'
						rel='noopener noreferrer'
						class='group relative block overflow-hidden rounded-2xl focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-red'
					>
						<img
							src={photo.img}
							alt={photo.alt}
							class='aspect-square w-full object-cover transition-transform duration-500 group-hover:scale-110'
							loading='lazy'
							decoding='async'
						/>
						<span
							class='absolute inset-0 grid place-items-center bg-brand-charcoal/0 text-white opacity-0 transition group-hover:bg-brand-charcoal/40 group-hover:opacity-100'
							aria-hidden='true'
						>
							<i class='ri-instagram-line text-3xl' />
						</span>
					</a>
				))
			}
		</div>
	</div>
</section>
