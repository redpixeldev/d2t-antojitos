---
import { site } from '@data/content';
---

<section
	id='top'
	class='relative isolate flex xl:min-h-[88vh] items-center overflow-hidden bg-brand-charcoal'
>
	<!-- Background image -->
	<img
		src='/img/hero.jpg'
		alt='An overhead spread of burgers, golden fries and iced drinks on a table'
		class='absolute inset-0 -z-10 size-full object-cover object-center'
		fetchpriority='high'
		decoding='async'
	/>
	<div
		class='absolute inset-0 -z-10 bg-gradient-to-r from-brand-charcoal/92 via-brand-charcoal/70 to-brand-charcoal/25'
		aria-hidden='true'
	>
	</div>

	<div class='container py-20'>
		<div class='max-w-2xl'>
			<p
				class='mb-6 inline-flex items-center gap-2 rounded-full bg-brand-amber px-5 py-2 text-xs font-bold tracking-[0.2em] text-brand-charcoal uppercase'
			>
				<i
					class='ri-map-pin-fill text-brand-charcoal'
					aria-hidden='true'></i>
				Magoon Square · Somerville
			</p>

			<h1 class='font-display text-6xl leading-[0.9] text-brand-cream uppercase sm:text-7xl lg:text-8xl'>
				<span class='block'>The Ultimate</span>
				<span class='block'>Dominican Food</span>
				<span class='block text-brand-amber'>Experience</span>
			</h1>

			<p class='mt-7 max-w-md text-lg text-white/80'>
				Explore authentic Dominican flavor at Antojitos, where every bite transports you to the streets of Santo
				Domingo.
			</p>

			<div class='mt-9 flex flex-wrap items-center gap-3'>
				<a
					href={site.phoneHref}
					class='btn btn-primary text-base'
				>
					<i
						class='ri-phone-fill'
						aria-hidden='true'></i>
					Call to Order
				</a>
				<a
					href='#menu'
					class='btn btn-outline text-base'
				>
					View Menu
					<i
						class='ri-arrow-right-line'
						aria-hidden='true'></i>
				</a>
			</div>
		</div>
	</div>
</section>
