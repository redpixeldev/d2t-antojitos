---
import type { MenuCategory } from '@data/content';
interface Props {
	category: MenuCategory;
}
const { category } = Astro.props;
---

<div class='overflow-hidden rounded-2xl border-2 border-brand-charcoal'>
	<!-- Header -->
	<div class='flex items-center gap-3 border-b border-brand-charcoal/15 px-5 py-3.5'>
		<span
			class='grid size-9 shrink-0 place-items-center rounded-lg bg-brand-charcoal text-brand-amber'
			aria-hidden='true'
		>
			<i class={`${category.icon} text-lg`}></i>
		</span>
		<h3 class='text-xl uppercase text-brand-charcoal'>{category.title}</h3>
	</div>

	<!-- Items -->
	<ul class='px-5 py-1'>
		{
			category.items.map((item) => (
				<li class='border-b border-dotted border-brand-charcoal/20 py-3 last:border-b-0'>
					<div class='flex items-baseline justify-between gap-4'>
						<span class='font-semibold text-brand-charcoal'>{item.name}</span>
						{item.price && <span class='shrink-0 font-bold text-brand-red'>{item.price}</span>}
					</div>
					{item.note && <p class='mt-1 text-xs leading-snug text-brand-ink/55'>{item.note}</p>}
				</li>
			))
		}
	</ul>
</div>
