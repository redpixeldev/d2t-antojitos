---
import { site } from '@data/content';
---

<!-- Sticky bottom Call-to-Order bar (mobile only) -->
<div
	class='fixed inset-x-0 bottom-0 z-50 border-t border-brand-cream-dark bg-brand-cream/95 p-3 backdrop-blur lg:hidden'
	style='padding-bottom: max(0.75rem, env(safe-area-inset-bottom));'
>
	<div class='flex gap-2'>
		<a
			href={site.phoneHref}
			class='btn btn-primary flex-1 text-base'
		>
			<i
				class='ri-phone-fill'
				aria-hidden='true'></i>
			Call to Order
		</a>
		<a
			href={site.address.mapsUrl}
			target='_blank'
			rel='noopener noreferrer'
			class='btn btn-dark shrink-0'
			aria-label='Get directions'
		>
			<i
				class='ri-navigation-fill text-lg'
				aria-hidden='true'></i>
		</a>
	</div>
</div>
<!-- Spacer so the fixed bar never covers footer content on mobile -->
<div
	class='h-20 lg:hidden'
	aria-hidden='true'
>
</div>
