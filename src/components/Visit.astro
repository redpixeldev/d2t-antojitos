---
import { hours, site } from '@data/content';
---

<section
	id='visit'
	class='scroll-mt-20 bg-brand-cream pt-16 pb-20 md:pb-24'
	aria-labelledby='visit-title'
>
	<div class='container grid items-start gap-12 lg:grid-cols-2 lg:gap-16'>
		<div>
			<p class='script-accent text-[#e33127]'>Come say hola</p>
			<h2
				id='visit-title'
				class='mt-1 text-4xl text-brand-charcoal uppercase md:text-6xl'
			>
				Visit Us
			</h2>

			<address class='mt-6 not-italic'>
				<p class='flex items-start gap-3 text-lg text-brand-ink'>
					<i
						class='ri-map-pin-2-fill mt-1 text-brand-red'
						aria-hidden='true'></i>
					<span>
						{site.address.street},<br />
						{site.address.city}
					</span>
				</p>
				<p class='mt-4 flex items-center gap-3 text-lg text-brand-ink'>
					<i
						class='ri-phone-fill text-brand-red'
						aria-hidden='true'></i>
					<a
						href={site.phoneHref}
						class='font-semibold hover:text-brand-red'>{site.phone}</a
					>
				</p>
			</address>

			<div class='mt-8 flex flex-wrap gap-3'>
				<a
					href={site.address.mapsUrl}
					target='_blank'
					rel='noopener noreferrer'
					class='btn btn-primary text-base'
				>
					<i
						class='ri-navigation-fill'
						aria-hidden='true'></i>
					Get Directions
				</a>
				<a
					href={site.phoneHref}
					class='btn border border-brand-charcoal bg-white text-base font-bold text-brand-charcoal transition-colors hover:bg-brand-charcoal hover:text-white'
				>
					<i
						class='ri-phone-fill'
						aria-hidden='true'></i>
					Call to Order
				</a>
			</div>
		</div>

		<!-- Opening hours card -->
		<div class='overflow-hidden rounded-2xl border-2 border-[#2a2017] bg-white shadow-lg shadow-brand-charcoal/10'>
			<div class='bg-[#2a2017] px-7 py-5'>
				<h3 class='font-body text-lg font-bold tracking-wide text-white uppercase'>Opening Hours</h3>
			</div>
			<dl class='px-7 pt-1 pb-12'>
				{
					hours.map((row, i) => (
						<div
							class={`flex items-center justify-between py-5 ${
								i < hours.length - 1 ? 'border-b border-dotted border-brand-charcoal/15' : ''
							}`}
						>
							<dt class='font-bold text-brand-charcoal'>{row.days}</dt>
							<dd class={row.closed ? 'font-bold text-brand-red' : 'font-bold text-[#2f9e44]'}>{row.time}</dd>
						</div>
					))
				}
			</dl>
		</div>
	</div>
</section>
