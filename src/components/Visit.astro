---
import { hours, site } from '@data/content';
---

<section
	id='visit'
	class='scroll-mt-20 bg-brand-cream py-20 md:py-28'
	aria-labelledby='visit-title'
>
	<div class='container grid gap-12 lg:grid-cols-2 lg:gap-16'>
		<div>
			<p class='script-accent text-brand-red'>Come say hola</p>
			<h2
				id='visit-title'
				class='mt-1 text-4xl uppercase md:text-6xl'
			>
				Visit Us
			</h2>

			<address class='mt-6 not-italic'>
				<p class='flex items-start gap-3 text-lg text-brand-ink'>
					<i
						class='ri-map-pin-2-fill mt-1 text-brand-red'
						aria-hidden='true'></i>
					<span>
						{site.address.street}<br />
						{site.address.city}
					</span>
				</p>
				<p class='mt-4 flex items-center gap-3 text-lg text-brand-ink'>
					<i
						class='ri-phone-fill text-brand-red'
						aria-hidden='true'></i>
					<a
						href={site.phoneHref}
						class='font-semibold hover:text-brand-red'>{site.phone}</a
					>
				</p>
			</address>

			<div class='mt-8 flex flex-wrap gap-3'>
				<a
					href={site.address.mapsUrl}
					target='_blank'
					rel='noopener noreferrer'
					class='btn btn-primary text-base'
				>
					<i
						class='ri-navigation-fill'
						aria-hidden='true'></i>
					Get Directions
				</a>
				<a
					href={site.phoneHref}
					class='btn btn-dark text-base'
				>
					<i
						class='ri-phone-fill'
						aria-hidden='true'></i>
					Call to Order
				</a>
			</div>
		</div>

		<!-- Opening hours -->
		<div class='rounded-3xl border border-brand-cream-dark bg-white/60 p-7 shadow-sm md:p-9'>
			<h3 class='flex items-center gap-3 text-2xl uppercase text-brand-charcoal'>
				<i
					class='ri-time-line text-brand-red'
					aria-hidden='true'></i>
				Opening Hours
			</h3>
			<dl class='mt-6 divide-y divide-brand-cream-dark'>
				{
					hours.map((row) => (
						<div class='flex items-center justify-between py-3.5'>
							<dt class='font-medium text-brand-ink'>{row.days}</dt>
							<dd class={row.closed ? 'font-semibold text-brand-red' : 'text-brand-ink/80'}>{row.time}</dd>
						</div>
					))
				}
			</dl>
		</div>
	</div>
</section>
